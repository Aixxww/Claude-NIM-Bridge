# ==================== Provider Selection ====================
# "nvidia_nim" (default) or "mimo"
PROVIDER=nvidia_nim

# ==================== Model ====================
# Primary model - all Claude requests are mapped to this
MODEL="z-ai/glm-5.2"
# Comma-separated fallback models for auto-rotation on 429/404/410
MODEL_FALLBACK="minimaxai/minimax-m3,deepseek-ai/deepseek-v4-flash,deepseek-ai/deepseek-v4-pro,qwen/qwen3.5-122b-a10b,qwen/qwen3.5-397b-a17b,mistralai/mistral-large-3-675b-instruct-2512,openai/gpt-oss-120b"

# ==================== NVIDIA NIM Config ====================
NVIDIA_NIM_API_KEY=""
NVIDIA_NIM_RATE_LIMIT=20
NVIDIA_NIM_RATE_WINDOW=60

# ==================== Xiaomi MiMo Config ====================
# Only needed when PROVIDER=mimo
MIMO_API_KEY=""
MIMO_BASE_URL="https://api.xiaomimimo.com/v1"
MIMO_MODEL="mimo-v2.5-pro"

# ==================== Optimization Flags ====================
FAST_PREFIX_DETECTION=true
LOG_FULL_PAYLOADS=true
ENABLE_NETWORK_PROBE_MOCK=true
ENABLE_TITLE_GENERATION_SKIP=true

NVIDIA_NIM_TEMPERATURE=1.0
NVIDIA_NIM_TOP_P=1.0
NVIDIA_NIM_MAX_TOKENS=16384
NVIDIA_NIM_SEED=42
NVIDIA_NIM_STOP=
